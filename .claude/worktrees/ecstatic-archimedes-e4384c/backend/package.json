{
  "name": "tracker-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "verify": "npm test && npm audit",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "deploy:prepare": "npm run db:generate && npm run db:migrate:deploy",
    "tracking:repair-display-history": "node scripts/repair-display-history.js",
    "format": "prettier --write .",
    "seed": "node prisma-seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Shipment tracking backend API",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.13.3",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-http-context": "^2.0.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mathjs": "^15.1.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "prisma": "^6.19.3",
    "supertest": "^6.3.4"
  }
}
