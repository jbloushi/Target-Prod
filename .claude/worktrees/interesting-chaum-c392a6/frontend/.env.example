# ============================================
# API Configuration
# ============================================
# Backend API base URL
VITE_API_URL=http://localhost:8899/api

# ============================================
# Google Maps Configuration
# ============================================
# Required for address search/autofill.
# Enable Maps JavaScript API, Places API, and Geocoding API in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=

# ============================================
# Mapbox Configuration (Optional)
# ============================================
VITE_MAPBOX_TOKEN=

# ============================================
# Feature Flags
# ============================================
VITE_ENABLE_PUBLIC_TRACKING=true

# Legacy Create React App names are still supported by Vite config:
# REACT_APP_API_URL=http://localhost:8899/api
# REACT_APP_GOOGLE_MAPS_API_KEY=
# REACT_APP_MAPBOX_TOKEN=
