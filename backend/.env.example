PORT=8899
NODE_ENV=development
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/target_logistics"
JWT_SECRET="replace-with-a-long-random-secret-min-64-chars"
# Required for HMAC-SHA256 API key hashing — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET="replace-with-a-separate-32-byte-hex-secret"
# Required for AES-256-GCM field encryption — 64 hex chars (32 bytes)
ENCRYPTION_KEY="replace-with-64-char-hex-string"
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
RATE_LIMIT_ENABLED=false

# Optional carrier and map credentials
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_API_URL=https://express.api.dhl.com/mydhlapi/test
GOOGLE_MAPS_API_KEY=

# Optional initial admin seed values used by npm run seed
ADMIN_ORGANIZATION_NAME=Target Logistics
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@target.local
ADMIN_PASSWORD=replace-with-a-temporary-local-password
