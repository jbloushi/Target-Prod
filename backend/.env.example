PORT=8899
NODE_ENV=development
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/target_logistics"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PUBLIC_TRACKING_BASE_URL=http://localhost:3000
SUPPORT_WHATSAPP_PHONE=96597691271
RATE_LIMIT_ENABLED=true

# Optional carrier and map credentials
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_API_URL=https://express.api.dhl.com/mydhlapi/test
LOGESTECHS_SHIPMENT_BASE_URL=https://apisv2.logestechs.com/api
LOGESTECHS_FULFILLMENT_BASE_URL=https://apisv5.logestechs.com/api
LOGESTECHS_COMPANY_ID=
LOGESTECHS_USERNAME=
LOGESTECHS_PASSWORD=
# Optional overrides for shipment create/cancel body auth
LOGESTECHS_EMAIL=
LOGESTECHS_SHIPMENT_EMAIL=
LOGESTECHS_SHIPMENT_PASSWORD=
GOOGLE_MAPS_API_KEY=

# Optional Chatwoot WhatsApp operational shipment notifications
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL=https://chatwoot.example.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
CHATWOOT_API_ACCESS_TOKEN=replace-with-chatwoot-api-access-token
# Set false to require approved WhatsApp templates for all operational messages.
CHATWOOT_ALLOW_PLAIN_TEXT_FALLBACK=true
# Optional JSON map. Keys may be event names or "event:recipientRole".
# Example:
# CHATWOOT_TEMPLATE_CONFIG={"shipment_created":{"name":"target_shipment_created","category":"UTILITY","language":"en_US"},"documents_needed":{"name":"target_documents_needed","category":"UTILITY","language":"en_US"},"on_hold_customs_issue":{"name":"target_customs_hold","category":"UTILITY","language":"en_US"},"delivery_attempt:receiver":{"name":"target_delivery_attempt","category":"UTILITY","language":"en_US"},"out_for_delivery:receiver":{"name":"target_out_for_delivery","category":"UTILITY","language":"en_US"}}
CHATWOOT_TEMPLATE_CONFIG=

# Optional initial admin seed values used by npm run seed
ADMIN_ORGANIZATION_NAME=Target Logistics
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@target.local
ADMIN_PASSWORD=replace-with-a-temporary-local-password
