# ========================================
# Production Environment Variables Template
# ========================================
# Copy this file to .env.production and fill in deployment values.
# Do not commit real secrets.

# Backend API URL. Use /api when the frontend and backend share a reverse proxy.
VITE_API_URL=/api

# Required for address autofill/search.
# Required Google APIs: Maps JavaScript API, Places API, Geocoding API.
VITE_GOOGLE_MAPS_API_KEY=

# Optional alternative map visualization token.
VITE_MAPBOX_TOKEN=
